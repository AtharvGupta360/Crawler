# ─────────────────────────────────────────────
# JobCrawl Configuration
# Copy this file to .env and fill in the values
# ─────────────────────────────────────────────

# Server
APP_ENV=development
APP_PORT=8080

# PostgreSQL
DATABASE_URL=postgres://jobcrawl:jobcrawl_dev_pass@localhost:5432/jobcrawl?sslmode=disable

# Redis
REDIS_URL=redis://localhost:6379

# Elasticsearch
ELASTICSEARCH_URL=http://localhost:9200

# Kafka
KAFKA_BROKERS=localhost:9094

# AI Providers (fill in at least one)
OPENAI_API_KEY=
GEMINI_API_KEY=

# Crawl Settings
CRAWL_RATE_LIMIT_PER_SECOND=1
CRAWL_MAX_CONCURRENT=5
CRAWL_USER_AGENT=JobCrawl/1.0 (+https://github.com/AtharvGupta360/JobCrawl)

# JWT Secret (generate a random 64-char string for production)
JWT_SECRET=dev-secret-change-in-production
